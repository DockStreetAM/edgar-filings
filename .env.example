# Copy to .env (gitignored) and fill in real values before re-recording
# integration cassettes with `uv run pytest tests/integration --record-mode=once`.
#
# Tokens are minted on the EDGAR Beta dashboard at
#   https://filermanagement-bravo.edgarfiling.sec.gov/
# See README.md → "Setting up an EDGAR Beta account".

# Filer API Token (1 year validity, JWT). Mint as Technical Administrator.
BETA_FILER_TOKEN=

# User API Token (30 days validity, JWT). Mint as account admin/user.
BETA_USER_TOKEN=

# Fictitious Beta CIK assigned to your test Form ID. Format: 10 digits.
BETA_CIK=

# CIK Confirmation Code (CCC) — per-CIK password for submissions, stamped
# into <cor:filerCcc>. Treat like a password. Quote in shells if it contains
# shell metacharacters (e.g. *, ?, $).
BETA_CCC=
